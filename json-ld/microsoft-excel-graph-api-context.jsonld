    "rowCount": { "@id": "ms:rowCount", "@type": "xsd:integer" },
    "hidden": { "@id": "ms:hidden", "@type": "xsd:boolean" },
    "visible": { "@id": "ms:visible", "@type": "xsd:boolean" },
    "type": { "@id": "ms:type", "@type": "xsd:string" },
    "value": { "@id": "ms:value", "@type": "xsd:string" }
  }
