    "NamedItem": "ms:NamedItem",
    "name": "schema:name",
    "description": "schema:description",
    "id": { "@id": "ms:id", "@type": "xsd:string" },
    "position": { "@id": "ms:position", "@type": "xsd:integer" },
    "visibility": { "@id": "ms:visibility", "@type": "xsd:string" },
