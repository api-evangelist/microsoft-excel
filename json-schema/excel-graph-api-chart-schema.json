{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/microsoft-excel/refs/heads/main/json-schema/excel-graph-api-chart-schema.json",
  "title": "Chart",
  "description": "Represents an Excel chart object.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the chart."
    },
    "name": {
      "type": "string",
      "description": "The name of the chart."
    },
    "height": {
      "type": "number",
      "format": "double",
      "description": "Height in points."
    },
    "width": {
      "type": "number",
      "format": "double",
      "description": "Width in points."
    },
    "left": {
      "type": "number",
      "format": "double",
      "description": "Left position in points."
    },
    "top": {
      "type": "number",
      "format": "double",
      "description": "Top position in points."
    }
  }
}
